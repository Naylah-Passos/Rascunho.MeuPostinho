<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MeuPostinhoAPI.Views.MinhasConsultasPage"
             Title="Consultas">

    <Grid BackgroundColor="#EEEEEE">

        <ScrollView>

            <VerticalStackLayout Padding="20" Spacing="15">

                <!-- Título -->
                <Label Text="Minhas Consultas"
                   FontSize="28"
                   TextColor="#2E7D32"
                   HorizontalOptions="Center"
                   FontAttributes="Bold"/>

                <!-- CARD 1 -->
                <Frame BackgroundColor="White"
                   Padding="20"
                   CornerRadius="12"
                   HasShadow="True">

                    <VerticalStackLayout Spacing="8">

                        <Label Text="Consulta Agendada"
                           FontSize="18"
                           TextColor="DimGrey"
                           FontAttributes="Bold"/>

                        <Label Text="Médico: Dr. João Silva"
                           TextColor="Black"/>

                        <Label Text="UBS: UBS Central"
                           TextColor="Gray"/>

                        <Label Text="Data: 25/04/2026"
                           TextColor="Gray"/>

                        <Label Text="Status: Confirmada"
                           TextColor="DarkSeaGreen"
                           FontAttributes="Bold"/>

                    </VerticalStackLayout>

                </Frame>

                <!-- CARD 2 -->
                <Frame BackgroundColor="White"
                   Padding="20"
                   CornerRadius="12"
                   HasShadow="True">

                    <VerticalStackLayout Spacing="8">

                        <Label Text="Consulta Agendada"
                           FontSize="18"
                           TextColor="DimGrey"
                           FontAttributes="Bold"/>

                        <Label Text="Médico: Dra. Ana Costa"
                           TextColor="Black"/>

                        <Label Text="UBS: UBS Norte"
                           TextColor="Gray"/>

                        <Label Text="Data: 28/04/2026"
                           TextColor="Gray"/>

                        <Label Text="Status: Pendente"
                           TextColor="Goldenrod"
                           FontAttributes="Bold"/>

                    </VerticalStackLayout>

                </Frame>

                <!-- CARD 3 -->
                <Frame BackgroundColor="White"
                   Padding="20"
                   CornerRadius="12"
                   HasShadow="True">

                    <VerticalStackLayout Spacing="8">

                        <Label Text="Consulta Agendada"
                           FontSize="18"
                           TextColor="DimGrey"
                           FontAttributes="Bold"/>

                        <Label Text="Médico: Dr. Carlos Lima"
                           TextColor="Black"/>

                        <Label Text="UBS: UBS Sul"
                           TextColor="Gray"/>

                        <Label Text="Data: 30/04/2026"
                           TextColor="Gray"/>

                        <Label Text="Status: Realizada"
                           TextColor="Gray"
                           FontAttributes="Bold"/>

                    </VerticalStackLayout>

                </Frame>

            </VerticalStackLayout>

        </ScrollView>

    </Grid>

</ContentPage>