<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MeuPostinhoAPI.Views.AdminHomePage"
             Title="AdminHomePage">
    
    <Grid BackgroundColor="#EEEEEE">
        <VerticalStackLayout 
            Padding="30"
            Spacing="25"
            VerticalOptions="Center">

            <!-- Título -->
            <Frame 
                CornerRadius="12" 
                Padding="8" 
                WidthRequest="340" 
                HasShadow="True">
                <Label
                    TextColor="DarkSeaGreen"
                    Text="Bem-vindo ao Meu Postinho"
                    FontSize="22"
                    HorizontalOptions="Center"/>
            </Frame>


            <!-- Botões grandes -->
            <Frame 
                CornerRadius="12" 
                Padding="0" 
                HasShadow="True">
                <Button 
                    BackgroundColor="DarkSeaGreen"
                    Text="Agendar Consulta"
                    HeightRequest="80" 
                    FontSize="18"
                    Clicked="Agendar_Clicked"/>
            </Frame>

            <Frame 
                CornerRadius="12" 
                Padding="0" 
                HasShadow="True">
                <Button 
                    BackgroundColor="DarkSeaGreen" 
                    Text="Ver Medicamentos" 
                    HeightRequest="80" 
                    FontSize="18" 
                    Clicked="Medicamentos_Clicked"/>
            </Frame>


            <Frame 
                CornerRadius="12" 
                Padding="0" 
                HasShadow="True">
                <Button  
                    BackgroundColor="DarkSeaGreen" 
                    Text="Minhas Consultas" 
                    HeightRequest="80" 
                    FontSize="18" 
                    Clicked="Consultas_Clicked"/>
            </Frame>

        </VerticalStackLayout>
    </Grid>
</ContentPage>