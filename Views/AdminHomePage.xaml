<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MeuPostinhoAPI.Views.AdminHomePage"
             Title="AdminHomePage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#EEEEEE">

    <ScrollView>

        <VerticalStackLayout
            Padding="25"
            Spacing="25">

            <!-- Header -->
            <Grid ColumnDefinitions="*,Auto">

                <VerticalStackLayout Spacing="4">

                    <Label
                        Text="Administrador 👨‍⚕️"
                        FontSize="18"
                        TextColor="DimGray" />

                    <Label
                        Text="Painel Meu Postinho"
                        FontSize="28"
                        FontAttributes="Bold"
                        TextColor="DarkSeaGreen" />

                </VerticalStackLayout>

            </Grid>

            <Label
                Text="Gerencie o sistema de saúde e acompanhe as informações."
                FontSize="15"
                TextColor="Gray" />

            <!-- AGENDA MÉDICA -->
            <Frame
                CornerRadius="18"
                Padding="0"
                BackgroundColor="White"
                BorderColor="#D9D9D9"
                HasShadow="True">

                <Grid Padding="20"
                      ColumnDefinitions="Auto,*">

                    <Frame
                        WidthRequest="65"
                        HeightRequest="65"
                        CornerRadius="32"
                        BackgroundColor="#E6F4EA"
                        HasShadow="False"
                        Padding="0">

                        <Label
                            Text="📅"
                            FontSize="28"
                            HorizontalOptions="Center"
                            VerticalOptions="Center" />
                    </Frame>

                    <VerticalStackLayout
                        Grid.Column="1"
                        Margin="15,0,0,0"
                        VerticalOptions="Center">

                        <Label
                            Text="Agenda Médica"
                            FontSize="20"
                            FontAttributes="Bold"
                            TextColor="#404040" />

                        <Label
                            Text="Gerencie consultas e atendimentos."
                            FontSize="14"
                            TextColor="Gray" />

                    </VerticalStackLayout>

                    <Button
                        Grid.ColumnSpan="2"
                        BackgroundColor="Transparent"
                        Clicked="Agendar_Clicked" />

                </Grid>
            </Frame>

            <!-- MEDICAMENTOS -->
            <Frame
                CornerRadius="18"
                Padding="0"
                BackgroundColor="White"
                BorderColor="#D9D9D9"
                HasShadow="True">

                <Grid Padding="20"
                      ColumnDefinitions="Auto,*">

                    <Frame
                        WidthRequest="65"
                        HeightRequest="65"
                        CornerRadius="32"
                        BackgroundColor="#E6F4EA"
                        HasShadow="False"
                        Padding="0">

                        <Label
                            Text="💊"
                            FontSize="28"
                            HorizontalOptions="Center"
                            VerticalOptions="Center" />
                    </Frame>

                    <VerticalStackLayout
                        Grid.Column="1"
                        Margin="15,0,0,0"
                        VerticalOptions="Center">

                        <Label
                            Text="Medicamentos"
                            FontSize="20"
                            FontAttributes="Bold"
                            TextColor="#404040" />

                        <Label
                            Text="Controle medicamentos disponíveis."
                            FontSize="14"
                            TextColor="Gray" />

                    </VerticalStackLayout>

                    <Button
                        Grid.ColumnSpan="2"
                        BackgroundColor="Transparent"
                        Clicked="Medicamentos_Clicked" />

                </Grid>
            </Frame>

            <!-- RELATÓRIOS -->
            <Frame
                CornerRadius="18"
                Padding="0"
                BackgroundColor="White"
                BorderColor="#D9D9D9"
                HasShadow="True">

                <Grid Padding="20"
                      ColumnDefinitions="Auto,*">

                    <Frame
                        WidthRequest="65"
                        HeightRequest="65"
                        CornerRadius="32"
                        BackgroundColor="#E6F4EA"
                        HasShadow="False"
                        Padding="0">

                        <Label
                            Text="📊"
                            FontSize="28"
                            HorizontalOptions="Center"
                            VerticalOptions="Center" />
                    </Frame>

                    <VerticalStackLayout
                        Grid.Column="1"
                        Margin="15,0,0,0"
                        VerticalOptions="Center">

                        <Label
                            Text="Relatórios"
                            FontSize="20"
                            FontAttributes="Bold"
                            TextColor="#404040" />

                        <Label
                            Text="Visualize consultas e dados do sistema."
                            FontSize="14"
                            TextColor="Gray" />

                    </VerticalStackLayout>

                    <Button
                        Grid.ColumnSpan="2"
                        BackgroundColor="Transparent"
                        Clicked="Consultas_Clicked" />

                </Grid>
            </Frame>

            <!-- SAIR -->
            <Button
                Text="Sair"
                BackgroundColor="DarkSeaGreen"
                TextColor="White"
                HeightRequest="55"
                CornerRadius="14"
                FontAttributes="Bold"
                Margin="0,10,0,30"
                Clicked="Logout_Clicked"/>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>