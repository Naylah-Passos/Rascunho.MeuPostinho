<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MeuPostinhoAPI.Views.AgendamentoPage"
             Title="Agendamento">


    <Grid BackgroundColor="#EEEEEE">

        <Frame WidthRequest="350" Padding="25" CornerRadius="12" HasShadow="True" HorizontalOptions="Center" VerticalOptions="Center">

            <VerticalStackLayout Spacing="15">

                <!-- Título -->
                <Label TextColor="DimGrey"
                       Text="Agendamento" FontSize="24"
                       HorizontalOptions="Center"/>

                <!-- Data -->
                <VerticalStackLayout Spacing="1">
                    <Label Text="Data"
                           TextColor="Grey"/>
                    <DatePicker x:Name="dataConsulta"
                                TextColor="Grey"/>
                </VerticalStackLayout>

                <!-- Hora -->
                <VerticalStackLayout Spacing="1">
                    <Label Text="Hora"
                           TextColor="Grey"/>
                    <TimePicker x:Name="horaConsulta" 
                                TextColor="Grey"/>
                </VerticalStackLayout>


                <!-- Médico -->
                <Entry TextColor="Black"
                       x:Name="txtMedico"
                       Placeholder="Nome do médico"/>

                <!-- UBS -->
                <Entry TextColor="Black"
                       x:Name="txtUBS"
                       Placeholder="Nome da UBS"/>

                <!-- Botão -->
                <Button BackgroundColor="DarkSeaGreen"
                        Text="Agendar"
                        HeightRequest="45"
                        Clicked="BtnAgendar_Clicked"/>


            </VerticalStackLayout>

        </Frame>

    </Grid>

</ContentPage>