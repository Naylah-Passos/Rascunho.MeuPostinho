<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MeuPostinhoAPI.Views.ResetPasswordPage"
             Title="Recuperar Senha"
             NavigationPage.HasNavigationBar="False">

    <Grid BackgroundColor="#EEEEEE">

        <!-- Card central -->
        <Frame BackgroundColor="GhostWhite"
               WidthRequest="400"
               Padding="30"
               CornerRadius="18"
               HasShadow="True"
               HorizontalOptions="Center"
               VerticalOptions="Center"
               Margin="25">

            <VerticalStackLayout Spacing="20">

                <!-- Ícone visual -->
                <Frame BackgroundColor="#E8F5E9"
                       CornerRadius="50"
                       HeightRequest="90"
                       WidthRequest="90"
                       Padding="20"
                       HorizontalOptions="Center"
                       HasShadow="False">

                    <Label Text="🔒"
                           FontSize="38"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Frame>

                <!-- Título -->
                <Label Text="Recuperar senha"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="#2E7D32"
                       HorizontalOptions="Center"/>

                <!-- Subtítulo -->
                <Label Text="Digite seu email para receber as instruções de recuperação da conta."
                       FontSize="14"
                       TextColor="DimGray"
                       HorizontalTextAlignment="Center"
                       LineBreakMode="WordWrap"/>

                <!-- Campo Email -->
                <VerticalStackLayout Spacing="6">

                    <Label Text="Email"
                           TextColor="DimGray"
                           FontSize="14"/>

                    <Frame CornerRadius="12"
                           BorderColor="#D9D9D9"
                           BackgroundColor="White"
                           Padding="10"
                           HasShadow="False">

                        <Entry x:Name="txtEmail"
                               Placeholder="Digite seu email"
                               Keyboard="Email"
                               TextColor="Black"
                               FontSize="16"/>
                    </Frame>

                </VerticalStackLayout>

                <!-- Botão principal -->
                <Button Text="Enviar instruções"
                        BackgroundColor="#2E7D32"
                        TextColor="White"
                        HeightRequest="55"
                        CornerRadius="12"
                        FontAttributes="Bold"
                        FontSize="16"
                        Clicked="OnSendClicked"/>

                <!-- Voltar -->
                <Label Text="Voltar para login"
                       TextColor="#2E7D32"
                       FontSize="14"
                       HorizontalOptions="Center">

                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackTapped"/>
                    </Label.GestureRecognizers>

                </Label>

            </VerticalStackLayout>

        </Frame>

    </Grid>

</ContentPage>