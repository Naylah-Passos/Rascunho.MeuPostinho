<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MeuPostinhoAPI.Views.HomePage"
             Title="Início">

    <VerticalStackLayout Padding="20" Spacing="15">

        <Label Text="Bem-vindo ao Meu Postinho" FontSize="20"/>

        <Button Text="Agendar Consulta" Clicked="Agendar_Clicked"/>
        <Button Text="Ver Medicamentos" Clicked="Medicamentos_Clicked"/>
        <Button Text="Minhas Consultas" Clicked="Consultas_Clicked"/>

    </VerticalStackLayout>
    
</ContentPage>